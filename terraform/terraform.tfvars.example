

# Example Terraform Variables File
# Copy this file to terraform.tfvars and customize the values

# AWS Configuration
aws_region = "us-east-1"  # Change to your preferred region
environment = "prod"      # dev, staging, prod

# Application Configuration
project_name = "fed-communications-ai"
container_port = 53788

# ECS Configuration
task_cpu = "512"          # 256, 512, 1024, 2048, 4096
task_memory = "1024"      # 512, 1024, 2048, 4096, 8192
desired_count = 2         # Number of running tasks

# Network Configuration
enable_nat_gateway = true  # Set to false to save costs (no outbound internet for private subnets)

# Monitoring Configuration
log_retention_days = 7
enable_container_insights = true

# Health Check Configuration
health_check_path = "/"

# Additional Tags
tags = {
  Project     = "fed-communications-ai"
  Owner       = "federal-reserve"
  Environment = "production"
  Department  = "communications"
  CostCenter  = "fed-comms-001"
}


